# ============================================
# B站收藏夹自动下载器 配置文件
# ============================================
#
# 使用说明：
# 1. 将此文件重命名为 config.yaml（去掉 .example 后缀）
# 2. 填写下面的配置项
# 3. 运行程序
#
# 获取 Cookie 方法：
#   1. 打开 Chrome 浏览器，登录 B站 (bilibili.com)
#   2. 按 F12 打开开发者工具
#   3. 切换到 "Network（网络）" 标签
#   4. 刷新页面，任意选择一个请求
#   5. 在请求头中找到 "Cookie" 字段，复制整个值
#   6. 粘贴到下面的 cookie 配置项中
#
# ============================================

# B站登录 Cookie（可选，不填则启动时自动扫码登录）
# 从浏览器开发者工具获取，必须包含 SESSDATA 字段
# 留空 = 启动时弹出浏览器展示二维码，手机扫码登录
cookie: ""

# 视频保存路径（必填）
# 程序会在此路径下按收藏夹分类存储视频
save_path: "./downloads"

# 起始日期（必填）
# 只监控此日期之后收藏的视频
# 之前收藏的会被跳过（标记为隔离，不会处理）
# 格式: YYYY-MM-DD
# 例如: 2026-04-01 表示只监控2026年4月1日之后收藏的视频
start_date: "2026-04-01"

# 检查间隔（分钟）
# 每隔多长时间检查一次收藏夹
# 建议至少30分钟，太频繁可能被B站风控
check_interval_minutes: 30

# 最大并发下载数
# 同时下载的视频数量
# 建议1-2，避免带宽占满或触发B站风控
max_concurrent_downloads: 1

# 下载质量
# bestvideo+bestaudio = 分离下载，最高画质（推荐，有大会员可选4K）
# best = 整体最清晰（无需额外合并，但画质可能稍低）
download_quality: "bestvideo+bestaudio"

# 下载超时时间（秒）
# 单个视频下载超过此时间会被判定为失败
# 默认1小时，一般足够
download_timeout_seconds: 3600

# 下载模式
# video = 下载完整视频（默认，需要 yt-dlp）
# metadata = 仅保存标题和描述到 txt 文件（无需 yt-dlp，适合备份已失效视频的信息）
download_mode: "video"

# 启用通知
# 启用后会在控制台打印详细信息
enable_notification: true

# ============================================
# 多收藏夹支持（新功能）
# ============================================

# 是否按收藏夹分类目录
# true = 保存路径为: {save_path}/{收藏夹名称}/{UP主}/{视频标题}
# false = 保存路径为: {save_path}/{UP主}/{视频标题}
# 建议开启，方便管理
favorite_folders: true

# 要监控的收藏夹列表
# 空列表 = 监控所有收藏夹（默认行为）
# 指定名称 = 只监控名称匹配的收藏夹
# 
# 示例：
#   - 只监控"默认收藏夹"和"AI"两个收藏夹：
#     monitored_favorites:
#       - "默认收藏夹"
#       - "AI"
#
#   - 监控所有收藏夹：
#     monitored_favorites: []
#     或者直接删除这个配置项
monitored_favorites: []
